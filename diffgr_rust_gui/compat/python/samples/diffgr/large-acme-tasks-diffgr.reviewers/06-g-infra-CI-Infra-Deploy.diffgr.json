  "groupBriefs": {
    "g-infra": {
      "status": "acknowledged",
      "summary": "CI に PostgreSQL サービスコンテナを追加し、マイグレーションを実行してから統合テストを走らせるフローに変更しました。また main push 時に Fly.io へ自動デプロイする deploy.yml を新規作成しています。",
      "focusPoints": [
        "ci.yml に postgres:16-alpine サービスを追加。ヘルスチェック付きで、DB が ready になるまでテストが待機します",
        "テスト前に npx prisma migrate deploy を実行。DATABASE_URL はテスト用の acme_tasks_test DB を指しています",
        "deploy.yml は main ブランチへの push のみトリガー。md/docs の変更は paths-ignore で除外しています",
        "Fly.io デプロイには FLY_API_TOKEN シークレットが必要です（GitHub Secrets への登録が必要）"
      ],
      "testEvidence": [
        "CI パイプライン自体の動作確認は push 後に実施が必要です"
      ],
      "knownTradeoffs": [
        "deploy.yml は CI 通過を待たずに deploy を実行します。CI と deploy を直列にしたい場合は workflow_run トリガーへの変更が必要です"
      ],
      "questionsForReviewer": [
        "FLY_API_TOKEN は GitHub リポジトリの Secrets に設定済みですか？",
        "deploy 前の CI 成功を必須にしますか？（workflow_run トリガーへの変更が必要です）"
      ]
    }
