        {
          "kind": "add",
          "text": "- `User` — id, email, passwordHash",
          "oldLine": null,
          "newLine": 18
        },
        {
          "kind": "add",
          "text": "- `Task` — id, title, description, status, tags, dueAt, ownerId, createdAt, updatedAt",
          "oldLine": null,
          "newLine": 19
        },
        {
          "kind": "add",
          "text": "- `RefreshToken` — id, token, userId, revokedAt, createdAt",
