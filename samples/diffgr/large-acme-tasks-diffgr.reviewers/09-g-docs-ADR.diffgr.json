        },
        {
          "kind": "add",
          "text": "## Overview",
          "oldLine": null,
          "newLine": 3
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 4
        },
        {
          "kind": "add",
          "text": "```",
          "oldLine": null,
          "newLine": 5
        },
        {
          "kind": "add",
          "text": "Browser → React SPA → Express API → PostgreSQL (Prisma)",
          "oldLine": null,
          "newLine": 6
        },
        {
          "kind": "add",
          "text": "```",
          "oldLine": null,
