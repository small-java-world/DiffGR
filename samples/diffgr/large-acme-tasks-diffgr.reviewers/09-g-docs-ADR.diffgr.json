        "start": 1,
        "count": 18
      },
      "lines": [
        {
          "kind": "add",
          "text": "# ADR 001 — Use Zod for request validation",
          "oldLine": null,
          "newLine": 1
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 2
        },
        {
          "kind": "add",
          "text": "**Status:** Accepted",
          "oldLine": null,
          "newLine": 3
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 4
        },
        {
          "kind": "add",
          "text": "## Context",
          "oldLine": null,
          "newLine": 5
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 6
        },
        {
          "kind": "add",
          "text": "Previously, request body validation was ad-hoc (manual `if` checks). This led to inconsistent error responses and missing fields silently passing through.",
          "oldLine": null,
          "newLine": 7
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 8
        },
        {
          "kind": "add",
          "text": "## Decision",
          "oldLine": null,
          "newLine": 9
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 10
        },
        {
          "kind": "add",
          "text": "Use Zod to define schemas for all request inputs. A thin `validate()` wrapper converts `ZodError` into a standardized `{ errors: FieldError[] }` response.",
          "oldLine": null,
          "newLine": 11
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 12
        },
        {
          "kind": "add",
          "text": "## Consequences",
          "oldLine": null,
          "newLine": 13
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 14
        },
        {
          "kind": "add",
          "text": "- Request shape is self-documenting and co-located with types",
          "oldLine": null,
          "newLine": 15
        },
        {
          "kind": "add",
          "text": "- 400 errors are consistent across all routes",
          "oldLine": null,
          "newLine": 16
        },
        {
          "kind": "add",
          "text": "- Runtime type safety from the boundary inward",
          "oldLine": null,
          "newLine": 17
        },
        {
          "kind": "add",
          "text": "",
          "oldLine": null,
          "newLine": 18
        }
      ],
